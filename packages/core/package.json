{
  "name": "@archora/forge-core",
  "version": "1.3.0",
  "description": "Core OpenAPI analysis and generation engine for Archora Forge.",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archora-dev/archora-forge.git"
  },
  "bugs": {
    "url": "https://github.com/archora-dev/archora-forge/issues"
  },
  "homepage": "https://github.com/archora-dev/archora-forge#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@archora/forge-config": "workspace:^",
    "jiti": "^2.7.0",
    "prettier": "^3.5.3",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "valibot": ">=0.30.0",
    "zod": ">=3.22.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "valibot": {
      "optional": true
    }
  }
}
