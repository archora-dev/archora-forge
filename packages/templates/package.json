{
  "name": "@archora/forge-templates",
  "version": "0.0.0",
  "description": "Template support for Archora Forge generated frontend modules.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/AKotofff/Archora-forge.git"
  },
  "bugs": {
    "url": "https://github.com/AKotofff/Archora-forge/issues"
  },
  "homepage": "https://github.com/AKotofff/Archora-forge#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
